---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="海景民宿 - 涠洲岛/防城港海景民宿运营">
  <section class="bg-gradient-to-r from-primary to-accent text-white py-16">
    <div class="container mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">海景民宿运营</h1>
      <p class="text-xl">涠洲岛 | 防城港 | 北海 | 专业民宿托管</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-6 max-w-4xl">
      <h2 class="text-2xl font-bold text-primary mb-6">热门海景民宿区域</h2>
      <div class="grid md:grid-cols-2 gap-6 mb-12">
        <div class="card">
          <h3 class="text-xl font-bold mb-3">涠洲岛</h3>
          <p class="text-gray-600 mb-4">火山岛海景民宿，旺季入住率95%+</p>
          <div class="text-accent">💰 月均收入：¥15,000-30,000</div>
        </div>
        <div class="card">
          <h3 class="text-xl font-bold mb-3">防城港</h3>
          <p class="text-gray-600 mb-4">边陲海港，性价比高的投资选择</p>
          <div class="text-accent">💰 月均收入：¥8,000-15,000</div>
        </div>
      </div>

      <h2 class="text-2xl font-bold text-primary mb-6">我们的服务</h2>
      <ul class="space-y-4 mb-12">
        <li class="flex items-start"><span class="text-accent mr-2">✓</span> 民宿设计装修指导</li>
        <li class="flex items-start"><span class="text-accent mr-2">✓</span> 平台上线与运营（携程、美团、途家）</li>
        <li class="flex items-start"><span class="text-accent mr-2">✓</span> 专业清洁与维护团队</li>
        <li class="flex items-start"><span class="text-accent mr-2">✓</span> 收益分析与优化建议</li>
        <li class="flex items-start"><span class="text-accent mr-2">✓</span> 法律合规与税务指导</li>
      </ul>

      <div class="bg-gray-50 p-8 rounded-xl">
        <h3 class="text-xl font-bold mb-4">免费获取民宿运营手册</h3>
        <p class="text-gray-600 mb-6">包含：选址指南、装修预算、运营checklist、收益测算表</p>
        <a href="/downloads/minsu-operation.pdf" class="btn-primary">下载PDF手册</a>
      </div>
    </div>
  </section>
</Layout>
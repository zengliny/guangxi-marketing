---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="学习资料 - 房产金融知识库">
  <section class="bg-gradient-to-r from-primary to-accent text-white py-16">
    <div class="container mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">房产金融知识库</h1>
      <p class="text-xl">定期更新，助您做出明智决策</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-6 max-w-6xl">
      <h2 class="text-2xl font-bold text-primary mb-8">最新学习资料</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        <div class="card">
          <div class="bg-accent/10 text-accent font-bold text-sm px-3 py-1 rounded-full inline-block mb-3">公积金</div>
          <h3 class="text-xl font-bold mb-3">公积金贷款完全指南</h3>
          <p class="text-gray-600 mb-4">从申请条件到放款流程，全面解析公积金贷款</p>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500">更新: 2026-04-05</span>
            <a href="/downloads/gjj-daikuan-guide.pdf" class="btn-primary text-sm px-4 py-2">下载</a>
          </div>
        </div>
        
        <div class="card">
          <div class="bg-accent/10 text-accent font-bold text-sm px-3 py-1 rounded-full inline-block mb-3">购房</div>
          <h3 class="text-xl font-bold mb-3">购房避坑攻略</h3>
          <p class="text-gray-600 mb-4">避免购房陷阱的15个实用技巧</p>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500">更新: 2026-04-05</span>
            <a href="/downloads/house-buying-guide.pdf" class="btn-primary text-sm px-4 py-2">下载</a>
          </div>
        </div>
        
        <div class="card">
          <div class="bg-accent/10 text-accent font-bold text-sm px-3 py-1 rounded-full inline-block mb-3">民宿</div>
          <h3 class="text-xl font-bold mb-3">民宿运营实战手册</h3>
          <p class="text-gray-600 mb-4">海景民宿运营全流程指南</p>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500">更新: 2026-04-05</span>
            <a href="/downloads/minsu-operation.pdf" class="btn-primary text-sm px-4 py-2">下载</a>
          </div>
        </div>
        
        <div class="card">
          <div class="bg-accent/10 text-accent font-bold text-sm px-3 py-1 rounded-full inline-block mb-3">投资</div>
          <h3 class="text-xl font-bold mb-3">房产投资入门</h3>
          <p class="text-gray-600 mb-4">新手房产投资的基础知识与策略</p>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500">更新: 2026-04-01</span>
            <a href="/downloads/property-investment.pdf" class="btn-primary text-sm px-4 py-2">下载</a>
          </div>
        </div>
        
        <div class="card">
          <div class="bg-accent/10 text-accent font-bold text-sm px-3 py-1 rounded-full inline-block mb-3">法律</div>
          <h3 class="text-xl font-bold mb-3">房产合同模板大全</h3>
          <p class="text-gray-600 mb-4">购房、出租、托管等常用合同模板</p>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500">更新: 2026-03-28</span>
            <a href="/downloads/contract-templates.zip" class="btn-primary text-sm px-4 py-2">下载</a>
          </div>
        </div>
        
        <div class="card">
          <div class="bg-accent/10 text-accent font-bold text-sm px-3 py-1 rounded-full inline-block mb-3">工具</div>
          <h3 class="text-xl font-bold mb-3">贷款计算器工具包</h3>
          <p class="text-gray-600 mb-4">Excel贷款计算器+还款计划表</p>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500">更新: 2026-03-25</span>
            <a href="/downloads/loan-calculator.xlsx" class="btn-primary text-sm px-4 py-2">下载</a>
          </div>
        </div>
      </div>
      
      <div class="bg-gray-50 p-8 rounded-xl text-center">
        <h3 class="text-xl font-bold mb-4">定期更新通知</h3>
        <p class="text-gray-600 mb-6">每周更新1-2篇专业内容，关注公众号获取最新资料</p>
        <div class="flex flex-col md:flex-row gap-4 justify-center">
          <a href="#" class="btn-primary">关注公众号</a>
          <a href="#" class="btn-secondary">加入学习群</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
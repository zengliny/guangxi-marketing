---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="公积金贷款 - 广西房产金融服务">
  <section class="bg-gradient-to-r from-primary to-accent text-white py-16">
    <div class="container mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">公积金贷款</h1>
      <p class="text-xl">最高额度 | 最低利率 | 快速审批</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-6 max-w-4xl">
      <h2 class="text-2xl font-bold text-primary mb-6">服务优势</h2>
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <div class="card text-center">
          <div class="text-4xl text-accent mb-4">💰</div>
          <h3 class="font-bold mb-2">最高50万</h3>
          <p class="text-gray-600">额度最高可达50万</p>
        </div>
        <div class="card text-center">
          <div class="text-4xl text-accent mb-4">📉</div>
          <h3 class="font-bold mb-2">利率低至3.1%</h3>
          <p class="text-gray-600">公积金贷款利率</p>
        </div>
        <div class="card text-center">
          <div class="text-4xl text-accent mb-4">⚡</div>
          <h3 class="font-bold mb-2">3天放款</h3>
          <p class="text-gray-600">快速审批放款</p>
        </div>
      </div>

      <h2 class="text-2xl font-bold text-primary mb-6">申请条件</h2>
      <ul class="space-y-3 mb-12">
        <li class="flex items-center"><span class="text-accent mr-2">✓</span> 正常缴存公积金6个月以上</li>
        <li class="flex items-center"><span class="text-accent mr-2">✓</span> 信用记录良好</li>
        <li class="flex items-center"><span class="text-accent mr-2">✓</span> 有稳定收入来源</li>
        <li class="flex items-center"><span class="text-accent mr-2">✓</span> 广西区内房产</li>
      </ul>

      <div class="bg-gray-50 p-8 rounded-xl text-center">
        <h3 class="text-xl font-bold mb-4">立即预约免费咨询</h3>
        <a href="tel:17200861361" class="btn-primary text-lg px-10">📞 172-0086-1361</a>
      </div>
    </div>
  </section>
</Layout>